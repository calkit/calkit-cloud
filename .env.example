# Domain
# This would be set to the production domain with an env var on deployment
DOMAIN=localhost

# Environment: local, staging, production
ENVIRONMENT=local

# Frontend URL for local development (used for Stripe checkout redirects)
FRONTEND_HOST=http://localhost:5173

PROJECT_NAME="Calkit"
STACK_NAME=calkit

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173,http://localhost.tiangolo.com"
SECRET_KEY=
FERNET_KEY=
# For key rotation: comma-separated list of keys, with the first being the active key
FERNET_KEYS=
FIRST_SUPERUSER=you@youremail.com
FIRST_SUPERUSER_PASSWORD=
FIRST_SUPERUSER_GITHUB_USERNAME=

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@calkit.io
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

SENTRY_DSN=

# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# MinIO
MINIO_ROOT_PASSWORD=

# GitHub
GH_CLIENT_ID=
GH_CLIENT_SECRET=
# GitHub App private key PEM contents (one line, use \n for newlines, or a
# quoted multi-line value). Lets GitHub-less members push. Optional in dev;
# without it they can only read public projects.
GH_APP_PRIVATE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Mixpanel
MIXPANEL_TOKEN=

# Zenodo
ZENODO_CLIENT_ID=
ZENODO_CLIENT_SECRET=

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Grafana (observability stack)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Zotero
ZOTERO_CLIENT_KEY=
ZOTERO_CLIENT_SECRET=
